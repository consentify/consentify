{
  "name": "@consentify/core",
  "version": "2.6.0",
  "description": "Headless cookie consent SDK - zero dependencies, TypeScript-first, SSR-safe.",
  "author": {
    "name": "Roman Denysov",
    "url": "https://github.com/RomanDenysov"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/RomanDenysov"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/romandenysov"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/romandenysov"
    }
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cookie",
    "consent",
    "cookie-consent",
    "cookie-banner",
    "consent-management",
    "gdpr",
    "ccpa",
    "eprivacy",
    "privacy",
    "headless",
    "ssr",
    "typescript",
    "zero-dependencies",
    "google-consent-mode",
    "consent-mode-v2",
    "broadcast-channel",
    "nextjs"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/consentify/consentify.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/consentify/consentify/issues"
  },
  "homepage": "https://github.com/consentify/consentify#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js && esbuild src/index.ts --bundle --format=esm --minify --outfile=dist/index.min.js && esbuild src/index.ts --bundle --format=iife --global-name=Consentify --outfile=dist/consentify.iife.js && esbuild src/index.ts --bundle --format=iife --global-name=Consentify --minify --sourcemap --outfile=dist/consentify.iife.min.js",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "rimraf": "6.0.1",
    "typescript": "5.9.3",
    "@types/node": "24.7.0"
  }
}